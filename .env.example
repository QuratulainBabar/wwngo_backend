PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wwngo

# JWT secrets (change in production)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_RESET_SECRET=change-me-reset-secret-min-32-chars

# Token lifetimes
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_RESET_EXPIRES_IN=15m

# OTP
OTP_EXPIRES_MINUTES=5
OTP_LENGTH=6
OTP_MAX_SENDS=3
OTP_SEND_WINDOW_MINUTES=15
# Fixed demo OTP for email verification (no real email sent)
DEMO_OTP_CODE=123456

# Login lockout
MAX_FAILED_LOGINS=5
LOCKOUT_MINUTES=15

# CORS (comma-separated origins, use * for dev)
CORS_ORIGINS=*
