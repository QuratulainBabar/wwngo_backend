# Sumsub KYC — use Sandbox credentials (App Token starts with sbx:)
# No spaces around '='. Do not commit real secrets.

SUMSUB_APP_TOKEN=sbx:your_sandbox_app_token
SUMSUB_SECRET_KEY=your_sandbox_secret_key
# Exact level name from Sumsub Dashboard → Sandbox → Verification levels
SUMSUB_LEVEL_NAME=basic-kyc-level
SUMSUB_WEBHOOK_SECRET=
# Same host for sandbox + production; environment is selected by sbx: token
SUMSUB_BASE_URL=https://api.sumsub.com
SUMSUB_TOKEN_TTL_SECS=600
